# ──────────────────────────────────────────────────────────────────────────────
# Soccer Engine — Variables de Entorno
# Copia este archivo como .env.local y rellena con tus credenciales reales.
# NUNCA subas .env.local a control de versiones.
# ──────────────────────────────────────────────────────────────────────────────



# ─── footballdata.io (https://footballdata.io/) ──────────────────────────────
# Obtén tu Bearer Token en el dashboard de footballdata.io.
VITE_FOOTBALLDATA_IO_KEY=your_bearer_token_here

# ─── Firebase (https://console.firebase.google.com/) ─────────────────────────
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID